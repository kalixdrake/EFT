# .gitignore for Django backend + React Native frontend
# Grouped and ordered for readability: OS, editors, Python, Django, envs, tools, Node/React Native

# ----- OS -----
.DS_Store

# ----- Editors / IDEs -----
.vscode/
.idea/
*.swp
*~

# ----- Python bytecode / caches -----
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# ----- Distribution / packaging -----
dist/
build/
eggs/
*.egg-info/
pip-wheel-metadata/

# ----- Virtual environments -----
env/
ENV/
venv/
.venv/
venv.bak/

# ----- Django / local files -----
# Database
db.sqlite3
db.sqlite3-journal

# Media/uploads and collected static (adjust if you track these)
media/
staticfiles/

# Local settings and secrets
local_settings.py
.env
.env.*.local
*.env

# Logs
*.log
logs/

# ----- Testing / coverage -----
.pytest_cache/
.tox/
.nox/
.coverage
coverage.xml
htmlcov/

# ----- Type checkers / caches -----
.mypy_cache/
.cache/

# ----- Node / React Native -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock
package-lock.json

# Android build
android/.gradle/
android/.idea/
android/app/build/
android/build/

# iOS build
ios/Pods/
ios/build/
*.xcworkspace
xcuserdata/
*.xcuserstate
ios/DerivedData/

# Gradle
.gradle/
build/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/

# ----- Secrets & keys -----
secret_key.txt
secrets.json

# ----- Misc -----
.DS_Store
Thumbs.db

# End of .gitignore
